<h1>My To-Do List</h1>

<ul>
  <% @tasks.each do |task| %>
    <li>
      <%= link_to task.title, "/tasks/#{task.id}" %> - <%= task.completed %>
    </li>
    <%= link_to "Delete",
      task_path(task),
      data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}
    %>
  <% end %>
</ul>

<%= link_to "Add a new task", "/new" %>
